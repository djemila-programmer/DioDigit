{
  "rules": {
    "sensors": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["timestamp"]
    },
    "esp32": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "history": {
      "$userId": {
        "readings": {
          ".read": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin')",
          ".write": "auth != null",
          ".indexOn": ["timestamp"]
        }
      }
    },
    "production": {
      "$userId": {
        ".read": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null"
      }
    }
  }
}
